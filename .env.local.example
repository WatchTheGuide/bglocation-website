# =============================================================================
# Lemon Squeezy — Checkout & Payments
# =============================================================================

# Checkout URLs for each plan (public — embedded in client-side HTML).
# Find them in LS Dashboard → Products → Share → Checkout URL.
# Example: https://yourstore.lemonsqueezy.com/buy/abcdef12-3456-7890-abcd-ef1234567890
NEXT_PUBLIC_LS_CHECKOUT_URL_INDIE=
NEXT_PUBLIC_LS_CHECKOUT_URL_TEAM=
NEXT_PUBLIC_LS_CHECKOUT_URL_FACTORY=

# Renewal checkout URLs (public — used in customer portal for expired licenses).
# Create separate one-time products in LS Dashboard for renewal.
NEXT_PUBLIC_LS_CHECKOUT_URL_RENEWAL_INDIE=
NEXT_PUBLIC_LS_CHECKOUT_URL_RENEWAL_TEAM=
NEXT_PUBLIC_LS_CHECKOUT_URL_RENEWAL_FACTORY=

# Webhook signing secret (server-side only).
# Find it in LS Dashboard → Settings → Webhooks → Signing secret.
LS_WEBHOOK_SECRET=

# API Key (server-side only — needed for portal/key generation in US-3).
# Find it in LS Dashboard → Settings → API.
LS_API_KEY=

# Variant IDs for mapping webhook events to plans (server-side only).
# Find them in LS Dashboard → Products → Variants.
LS_VARIANT_INDIE=
LS_VARIANT_TEAM=
LS_VARIANT_FACTORY=
LS_VARIANT_ENTERPRISE=

# Renewal variant IDs (server-side only).
LS_VARIANT_RENEWAL_INDIE=
LS_VARIANT_RENEWAL_TEAM=
LS_VARIANT_RENEWAL_FACTORY=
LS_VARIANT_RENEWAL_ENTERPRISE=

# =============================================================================
# Database — PostgreSQL (Prisma)
# =============================================================================

# PostgreSQL connection string.
# Example: postgresql://user:password@localhost:5432/bglocation
DATABASE_URL=

# =============================================================================
# Authentication
# =============================================================================

# Secret for signing JWT tokens (portal + admin sessions).
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# =============================================================================
# License Key Signing — RSA
# =============================================================================

# RSA private key for signing license keys (PEM format, server-side only).
# Generate with: openssl genrsa 2048
# Store the full PEM including -----BEGIN/END----- markers.
RSA_PRIVATE_KEY=

# =============================================================================
# Email — Resend
# =============================================================================

# Resend API key for transactional emails (server-side only).
# Find it at https://resend.com/api-keys
# Optional — if unset, emails are silently skipped.
RESEND_API_KEY=

# Sender address for outgoing emails.
# Optional — defaults to "BGLocation <no-reply@bglocation.dev>".
# EMAIL_FROM=BGLocation <no-reply@bglocation.dev>

# =============================================================================
# OpenAI — AI Chat Widget
# =============================================================================

# OpenAI API key (server-side only).
# Find it at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# =============================================================================
# HTTP Test Endpoint
# =============================================================================

# Shared secret to gate the HTTP test endpoint in production (server-side only).
# If set, requests must include ?secret=<value> to use the endpoint.
# In development, the endpoint works without a secret.
# Generate with: openssl rand -hex 32
HTTP_TEST_SECRET=

# Allowed CORS origin for the HTTP test endpoint (public).
# Optional — defaults to '*' in development, '' (disabled) in production.
# NEXT_PUBLIC_HTTP_TEST_ALLOWED_ORIGIN=https://bglocation.dev

# =============================================================================
# App URL
# =============================================================================

# Public app URL used for Origin validation in API routes.
# Use http://localhost:3000 for local development.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
